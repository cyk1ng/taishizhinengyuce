# =============================================
# 模型配置选择说明
# =============================================
# 本文件提供云端模型和本地模型的配置示例
# 根据需要选择其中一种配置方式

# ============================================================
# 选项 1：云端模型（火山引擎 ARK）
# ============================================================
# 优点：性能稳定、无需本地资源、无需下载模型
# 缺点：需要网络、可能有费用、依赖云服务
# 适用：开发测试、资源受限环境

# 云端模型配置
# COZE_WORKLOAD_IDENTITY_API_KEY=038329bc-1212-4df1-962c-6dfaf299e2c7
# COZE_INTEGRATION_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 对应的 agent_llm_config.json 模型名称
# model: doubao-seed-1-8-251228


# ============================================================
# 选项 2：本地模型（Ollama）
# ============================================================
# 优点：无需网络、数据隐私、可控性强、成本为零
# 缺点：需要本地资源、需要下载模型、性能取决于硬件
# 适用：生产环境、离线部署、数据敏感场景

# 本地模型配置（当前使用）
COZE_WORKLOAD_IDENTITY_API_KEY=ollama
COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:11434/v1

# 对应的 agent_llm_config.json 模型名称
# model: qwen2.5:7b


# ============================================================
# 选项 3：本地模型（vLLM）
# ============================================================
# 优点：高性能、支持批量推理、适合生产环境
# 缺点：资源要求高、配置复杂
# 适用：高并发场景、企业级应用

# vLLM 模型配置
# COZE_WORKLOAD_IDENTITY_API_KEY=not-needed
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:8000/v1

# 对应的 agent_llm_config.json 模型名称
# model: Qwen/Qwen2.5-7B-Instruct


# ============================================================
# 选项 4：其他本地服务
# ============================================================
# 如使用 LM Studio、text-generation-webui 等其他本地服务
# 修改 BASE_URL 为对应的地址即可

# LM Studio 示例
# COZE_WORKLOAD_IDENTITY_API_KEY=not-needed
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:1234/v1

# text-generation-webui 示例
# COZE_WORKLOAD_IDENTITY_API_KEY=not-needed
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:5000/v1


# ============================================================
# 如何切换模型配置
# ============================================================
# 方法 1：修改 .env 文件
# 1. 打开 .env 文件
# 2. 注释掉当前配置（在行首添加 #）
# 3. 取消注释目标配置（删除行首的 #）
# 4. 保存文件
# 5. 重启系统服务

# 方法 2：使用 .env.local 文件（推荐）
# 1. 创建 .env.local 文件
# 2. 只添加需要修改的配置项
# 3. .env.local 的配置会覆盖 .env
# 4. 保存文件
# 5. 重启系统服务

# 示例：.env.local 文件内容（切换到云端模型）
# COZE_WORKLOAD_IDENTITY_API_KEY=038329bc-1212-4df1-962c-6dfaf299e2c7
# COZE_INTEGRATION_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3


# ============================================================
# 配置对比
# ============================================================
#
# | 配置项 | 云端模型 | 本地模型(Ollama) | 本地模型(vLLM) |
# |-------|---------|----------------|----------------|
# | API_KEY | 需要密钥 | ollama | not-needed |
# | BASE_URL | 火山引擎地址 | localhost:11434/v1 | localhost:8000/v1 |
# | 模型名称 | doubao-seed-1-8-251228 | qwen2.5:7b | Qwen/Qwen2.5-7B-Instruct |
# | 网络依赖 | 是 | 否 | 否 |
# | 资源需求 | 低 | 中(8GB) | 高(16GB) |
# | 响应速度 | 快 | 中(取决于硬件) | 快 |
# | 数据隐私 | 取决于云端 | 本地 | 本地 |
# | 成本 | 按使用量 | 免费 | 免费 |
# | 适用场景 | 开发测试 | 生产环境 | 高并发 |
#
