# ============================================================
# 数据库配置（Oracle）
# ============================================================
DB_TYPE=oracle
DB_HOST=your_oracle_host          # Oracle服务器地址（如：192.168.1.100）
DB_PORT=1521                       # Oracle端口，默认1521
DB_NAME=ORCL                       # Oracle服务名（SID）
DB_USER=your_username              # 数据库用户名
DB_PASSWORD=your_password          # 数据库密码

# 或者使用完整URL（优先级更高）
# DATABASE_URL=oracle+cx_oracle://username:password@host:1521/?service_name=ORCL

# ============================================================
# 大模型配置
# ============================================================
# API密钥（从Coze平台或模型提供商获取）
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here

# 模型API端点（根据实际模型提供商配置）
COZE_INTEGRATION_MODEL_BASE_URL=https://your-model-endpoint.com

# ============================================================
# 其他配置
# ============================================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 工作空间路径（通常不需要修改）
WORKSPACE_PATH=/workspace/projects
