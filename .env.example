# ========================================
# Coze Coding 环境变量配置模板
# ========================================
# 使用方法：复制此文件为 .env，并填写实际值

# ========================================
# 1. 工作空间路径（必填）
# ========================================
# Windows 示例：COZE_WORKSPACE_PATH=F:\Work\WorkSpace\aiWork\projects
# Linux/Mac 示例：COZE_WORKSPACE_PATH=/workspace/projects
COZE_WORKSPACE_PATH=F:\Work\WorkSpace\aiWork\projects

# ========================================
# 2. 模型认证配置（必填）
# ========================================
# 方式1：使用 Coze 云端环境（推荐）
# 在 Coze 云端运行时，以下变量会自动注入，无需设置
COZE_WORKLOAD_IDENTITY_API_KEY=nG0VPUEtA6vmn0YQCCwC1XHqAzzSqHBpHbIX4Kabuno
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn/v1

# 方式2：使用 OpenAI API（备选）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 方式3：使用火山引擎（豆包模型）
# ARK_API_KEY=xxxxxxxxxxxxxxxx

# ========================================
# 3. 数据库配置（必填 - 选择其中一种）
# ========================================

# ---------- MySQL 配置 ----------
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dispatch_db
DB_USER=root
DB_PASSWORD=your_password

# ---------- Oracle 配置 ----------
# DB_TYPE=oracle
# DB_HOST=localhost
# DB_PORT=1521
# DB_NAME=ORCL
# DB_USER=system
# DB_PASSWORD=your_password

# ---------- PostgreSQL 配置 ----------
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dispatch_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ---------- 或使用完整 URL ----------
# MySQL: DATABASE_URL=mysql+pymysql://root:password@localhost:3306/dispatch_db
# Oracle: DATABASE_URL=oracle+cx_oracle://system:password@localhost:1521/?service_name=ORCL
# PostgreSQL: DATABASE_URL=postgresql://postgres:password@localhost:5432/dispatch_db

# ========================================
# 4. 外部API配置（可选）
# ========================================
# 天气API（和风天气免费版）
# 申请地址：https://dev.qweather.com/
# WEATHER_API_KEY=your_qweather_api_key
# WEATHER_API_ENDPOINT=https://devapi.qweather.com/v7
# DEFAULT_CITY=101010100  # 北京城市代码
