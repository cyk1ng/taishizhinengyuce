# ========================================
# Coze Coding 环境变量配置模板
# ========================================
# 使用方法：复制此文件为 .env，并填写实际值

# ========================================
# 1. 工作空间路径（必填）
# ========================================
# Windows 示例：COZE_WORKSPACE_PATH=F:\Work\WorkSpace\aiWork\projects
# Linux/Mac 示例：COZE_WORKSPACE_PATH=/workspace/projects
COZE_WORKSPACE_PATH=F:\Work\WorkSpace\aiWork\projects

# ========================================
# 2. 模型认证配置（必填）
# ========================================
# 方式1：使用 Coze 云端环境（推荐）
# 在 Coze 云端运行时，以下变量会自动注入，无需设置
COZE_WORKLOAD_IDENTITY_API_KEY=nG0VPUEtA6vmn0YQCCwC1XHqAzzSqHBpHbIX4Kabuno
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn/v1

# 方式2：使用 OpenAI API（备选）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 方式3：使用火山引擎（豆包模型）
# ARK_API_KEY=xxxxxxxxxxxxxxxx

# ========================================
# 3. 数据库配置（可选）
# ========================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dispatch_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ========================================
# 4. 外部API配置（可选）
# ========================================
# 天气API（和风天气免费版）
# 申请地址：https://dev.qweather.com/
# WEATHER_API_KEY=your_qweather_api_key
# WEATHER_API_ENDPOINT=https://devapi.qweather.com/v7
# DEFAULT_CITY=101010100  # 北京城市代码

# 设备状态API
# EQUIPMENT_API_ENDPOINT=https://api.equipment.com
