WEATHER_API_KEY=44ff4071f86641979f59da2daed5505e
WEATHER_API_ENDPOINT=https://devapi.qweather.com/v7
DEFAULT_CITY=101280101

# ========================================
# 本地模型部署快速启动指南
# ========================================
# 1. 安装 Ollama（最简单）：
#    - Windows：访问 https://ollama.com/download 下载安装
#    - 验证：打开命令行运行 ollama --version
#
# 2. 拉取中文模型（推荐）：
#    - ollama pull qwen2.5:7b（通义千问 7B，中文效果好）
#    - ollama pull qwen2.5:14b（通义千问 14B，效果更好）
#    - ollama pull llama3.1:8b（Llama 3.1 8B，通用性强）
#
# 3. 启动服务：
#    - ollama serve
#    - 服务地址：http://localhost:11434
#
# 4. 验证服务：
#    - 浏览器访问：http://localhost:11434/api/tags
#    - 命令行测试：curl http://localhost:11434/api/tags
#
# 5. 修改模型配置：
#    - 编辑 config/agent_llm_config.json
#    - 将 "model" 字段改为本地模型名称，如 "qwen2.5:7b"
#
# 6. 测试系统：
#    - 重启 Python 服务
#    - 运行测试验证本地模型是否正常工作

# ========================================
# 硬件要求建议
# ========================================
# 7B 模型：需要 8GB+ 显存（RTX 3060及以上）
# 14B 模型：需要 16GB+ 显存（RTX 4080及以上）
# 无显卡：使用 CPU 推理（速度较慢，但可用）
# 建议：优先选择 Ollama，会自动优化硬件利用率
