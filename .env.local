# ========================================
# Coze Coding 环境变量配置
# ========================================

# 工作空间路径
COZE_WORKSPACE_PATH=F:\Work\WorkSpace\aiWork\projects

# ========================================
# 模型认证配置 - 本地部署方案
# ========================================

# 方案1：使用 Ollama（推荐）
# 安装：https://ollama.com/
# 启动：ollama serve
# 拉取模型：ollama pull qwen2.5:7b 或 ollama pull llama3.1:8b
COZE_WORKLOAD_IDENTITY_API_KEY=ollama
COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:11434/v1

# 方案2：使用 vLLM（高性能推理）
# 安装：pip install vllm
# 启动：python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-7B-Instruct --port 8000
# COZE_WORKLOAD_IDENTITY_API_KEY=vllm
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:8000/v1

# 方案3：使用 LM Studio（图形界面）
# 下载：https://lmstudio.ai/
# 启动后默认地址：http://localhost:1234/v1
# COZE_WORKLOAD_IDENTITY_API_KEY=lm-studio
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:1234/v1

# 方案4：使用 text-generation-webui（Oobabooga）
# 安装：https://github.com/oobabooga/text-generation-webui
# 启动后API地址：http://localhost:5000/v1
# COZE_WORKLOAD_IDENTITY_API_KEY=oobabooga
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:5000/v1

# 方案5：使用 LocalAI
# 安装：https://localai.io/
# 默认地址：http://localhost:8080/v1
# COZE_WORKLOAD_IDENTITY_API_KEY=localai
# COZE_INTEGRATION_MODEL_BASE_URL=http://localhost:8080/v1

# ========================================
# 本地模型名称配置（可选）
# ========================================
# 如果不配置，系统会使用 agent_llm_config.json 中的默认模型
# LOCAL_MODEL_NAME=qwen2.5:7b
# LOCAL_MODEL_NAME=llama3.1:8b
# LOCAL_MODEL_NAME=qwen:14b

# ========================================
