# 在Windows上运行 ipconfig 命令查看IPv4地址
DATABASE_URL=mysql+pymysql://root:Chenyongkun0629-@192.168.1.100:3306/dispatch_system?charset=utf8mb4
DB_TYPE=mysql
DB_HOST=192.168.1.100
DB_PORT=3306
DB_NAME=dispatch_system
DB_USER=root
