{
  "staffing_rules": {
    "base_ratio": {
      "dispatches_per_person": 8,
      "faults_per_person": 2,
      "emergency_buffer_ratio": 0.2,
      "description": "每人每日处理调度次数和故障数基准"
    },
    "shift_structure": {
      "shifts_per_day": 3,
      "shift_hours": [8, 8, 8],
      "shift_names": ["早班", "中班", "晚班"],
      "shift_times": {
        "早班": "08:00-16:00",
        "中班": "16:00-24:00",
        "晚班": "00:00-08:00"
      },
      "min_staff_per_shift": 2,
      "max_staff_per_shift": 10
    },
    "skills": [
      {
        "name": "调度操作",
        "category": "core",
        "required_count": 1,
        "description": "基础调度操作能力"
      },
      {
        "name": "故障处理",
        "category": "specialized",
        "required_count": 1,
        "description": "故障诊断与处理能力"
      },
      {
        "name": "应急响应",
        "category": "advanced",
        "required_count": 1,
        "description": "紧急事件处理能力"
      },
      {
        "name": "高压操作",
        "category": "specialized",
        "required_count": 0,
        "description": "高压设备操作资质"
      }
    ]
  },
  "constraints": {
    "max_work_hours_per_day": 12,
    "min_rest_hours_between_shifts": 8,
    "max_consecutive_work_days": 6,
    "min_rest_days_per_week": 1,
    "overtime_limit_hours_per_month": 36,
    "compliance_check": true,
    "labor_law_reference": "《劳动法》第四十一条"
  },
  "optimization": {
    "objective": "balance_workload",
    "factors": {
      "workload_balance": 0.4,
      "skill_coverage": 0.3,
      "cost_efficiency": 0.3
    },
    "algorithm": "heuristic",
    "max_iterations": 100
  },
  "escalation_rules": [
    {
      "condition": "predicted_dispatches > 100",
      "action": "request_additional_staff",
      "priority": "high",
      "notify": ["调度主管", "人力资源部"]
    },
    {
      "condition": "risk_level == '高'",
      "action": "activate_emergency_protocol",
      "priority": "critical",
      "notify": ["调度主管", "安全管理部门"]
    }
  ],
  "cost_factors": {
    "base_hourly_rate": 50,
    "overtime_multiplier": 1.5,
    "night_shift_multiplier": 1.3,
    "holiday_multiplier": 3.0,
    "currency": "CNY"
  }
}
