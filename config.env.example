# ==========================================
# 配网调度业务量智能预测系统 - 环境配置
# ==========================================
# 使用方法：复制为 config.env，修改实际值
# docker run --env-file config.env ...
# ==========================================

# ===== Oracle 数据库配置 =====
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=

# ===== 大模型配置 =====
# 模型服务地址（Ollama: http://内网IP:11434/v1, 智谱: https://open.bigmodel.cn/api/paas/v4/）
COZE_INTEGRATION_MODEL_BASE_URL=http://10.180.144.249:11434/v1
# API Key（Ollama 不需要 key，填任意值；智谱填自己的 key）
COZE_WORKLOAD_IDENTITY_API_KEY=ollama
# 模型名称（Ollama: qwen2.5:14b, 智谱: glm-4-flash）
COZE_MODEL_NAME=qwen2.5:14b
# 温度参数（0-1，越小越确定，越大越随机）
COZE_TEMPERATURE=0.7
# 最大输出 tokens
COZE_MAX_TOKENS=8000
# 请求超时（秒）
COZE_TIMEOUT=600

# ===== 应用配置 =====
# 使用 Ollama 的配置（config/agent_llm_config_docker.json）
COZE_LLM_CONFIG=config/agent_llm_config_docker.json
# false=连接真实数据库, true=跳过数据库用假数据
SKIP_DB=false