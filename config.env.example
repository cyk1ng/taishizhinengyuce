# ==========================================
# 配网调度业务量智能预测系统 - 环境配置
# ==========================================
# 使用方法：复制为 config.env，修改实际值
# docker run --env-file config.env ...
# ==========================================

# ===== Oracle 数据库配置 =====
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=

# ===== Ollama 模型配置 =====
# Ollama 服务地址（容器内访问宿主机）
COZE_INTEGRATION_MODEL_BASE_URL=http://10.180.144.249:11434/v1
# Ollama 不需要 key，填任意值
COZE_WORKLOAD_IDENTITY_API_KEY=ollama

# ===== 应用配置 =====
# 使用 Ollama 的配置（config/agent_llm_config_docker.json）
COZE_LLM_CONFIG=config/agent_llm_config_docker.json
# false=连接真实数据库, true=跳过数据库用假数据
SKIP_DB=false